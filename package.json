{
  "name": "vstools",
  "version": "0.1.0",
  "description": "A browser-based toolset for Vagrant Story (2000, Square). Contains a mostly working model viewer.",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --single-quote --write src/*.js test/*.js",
    "test": "node --import ./test/register-loader.js test/test.js",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit",
    "serve": "http-server -c-1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/morris/vstools.git"
  },
  "author": "Morris Brodersen <mb@morrisbrodersen.de>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/morris/vstools/issues"
  },
  "homepage": "https://github.com/morris/vstools",
  "dependencies": {
    "pngjs": "^7.0.0",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^25.6.2",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "http-server": "^14.1.1",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
